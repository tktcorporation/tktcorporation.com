{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check && npm run lint:actions && npm run check:node-types",
    "check:node-types": "tsx scripts/check-node-types-version.ts",
    "lint": "vp lint && npm run lint:actions",
    "lint:actions": "node-actionlint",
    "format": "vp fmt --write",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc",
    "screenshot": "tsx scripts/screenshot.ts",
    "test": "vp test",
    "test:ui": "vp test --ui",
    "test:run": "vp test run",
    "test:coverage": "vp test run --coverage",
    "test:e2e": "playwright test tests/e2e/",
    "test:e2e:ui": "playwright test tests/e2e/ --ui",
    "test:all": "npm run test:run && npm run test:e2e",
    "test:display": "tsx scripts/test-display.ts",
    "update:lapras": "tsx scripts/update-lapras-data.ts",
    "knip": "knip"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "13.13.0",
    "@qwik.dev/partytown": "^0.11.2",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.13.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.5.0",
    "vite": "8.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@tktco/node-actionlint": "1.6.0",
    "@types/node": "24.12.0",
    "devicon": "2.17.0",
    "happy-dom": "20.8.4",
    "knip": "5.61.2",
    "playwright": "1.58.2",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-plus": "0.1.13-alpha.5"
  },
  "simple-git-hooks": {
    "pre-push": "npm run check && npm run typecheck"
  },
  "engines": {
    "node": "24"
  }
}
